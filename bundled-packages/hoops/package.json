      "options": [
        {
          "id": "name",
          "label": "Name",
          "type": "textinput",
          "default": ""
        },
        {
          "id": "number",
          "label": "Number",
          "type": "textinput",
          "default": ""
        },
        {
          "id": "info",
          "label": "Info line",
          "type": "textinput",
          "default": ""
