        {
          "op": "set",
          "field": "playerCard.number",
          "value": {
            "option": "number",
            "orState": "playerCard.number"
          }
        },
        {
          "op": "set",
          "field": "playerCard.info",
          "value": {
            "option": "info",
            "orState": "playerCard.info"
          }
        },
        {
          "op": "set",
          "field": "playerCard.pts",
          "value": {
            "option": "pts"
          }
        },
        {
          "op": "set",
          "field": "playerCard.reb",
          "value": {
            "option": "reb"
          }
        },
        {
          "op": "set",
          "field": "playerCard.ast",
          "value": {
            "option": "ast"
          }
        },
        {
          "op": "set",
          "field": "playerCard.fg",
          "value": {
            "option": "fg",
            "orState": "playerCard.fg"
          }
        }
      ]
    },
    {
      "id": "set_team_name_home",
      "label": "Set home team name",
      "options": [
        {
          "id": "name",
          "label": "Team (3-letter)",
          "type": "textinput",
          "default": "BOS"
        }
      ],
      "ops": [
        {
          "op": "set",
          "field": "teamA",
          "value": {
