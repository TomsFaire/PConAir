{
  "id": "hoops",
  "name": "COURTVISION Basketball",
  "version": "1.0.0",
  "description": "NBA-style basketball scorebug with shot clock, player stat card, network bug, and ticker",
  "renders": [
    {
      "id": "scorebug",
      "label": "Scorebug",
      "file": "render.html"
    }
  ],
  "stateSchema": {
    "teamA": "string",
    "teamB": "string",
    "scoreA": "number",
    "scoreB": "number",
    "clock": "string",
    "clockEndsAt": "number",
    "shotClock": "number",
    "shotEndsAt": "number",
    "quarter": "number",
    "possession": "string",
    "bonusA": "boolean",
    "bonusB": "boolean",
    "timeoutsA": "number",
    "timeoutsB": "number",
    "netBugVisible": "boolean",
    "venue": "string",
    "playerCard": {
      "visible": "boolean",
      "name": "string",
      "number": "string",
      "info": "string",
      "pts": "number",
      "reb": "number",
      "ast": "number",
      "fg": "string"
    },
    "tickerVisible": "boolean",
    "tickerTag": "string"
  },
  "initialState": {
    "teamA": "BOS",
    "teamB": "LAL",
    "scoreA": 88,
    "scoreB": 84,
    "clock": "07:42",
    "clockEndsAt": 0,
    "shotClock": 14,
    "shotEndsAt": 0,
    "quarter": 3,
    "possession": "a",
    "bonusA": false,
    "bonusB": false,
    "timeoutsA": 5,
    "timeoutsB": 4,
    "netBugVisible": true,
    "venue": "TD Garden",
    "playerCard": {
      "visible": false,
      "name": "J. TATUM",
      "number": "0",
      "info": "BOSTON \u00b7 SF",
      "pts": 31,
      "reb": 9,
      "ast": 7,
      "fg": "11-19"
    },
    "tickerVisible": true,
    "tickerTag": "AROUND THE LEAGUE",
    "tickerItems": [
      "GSW 112 \u00b7 DEN 108 \u00b7 FINAL",
      "MIA 89 \u00b7 NYK 91 \u00b7 3Q 2:14",
      "DAL 77 \u00b7 PHX 74 \u00b7 HALF",
      "MIL 103 \u00b7 PHI 99 \u00b7 4Q 5:30",
      "OKC 120 \u00b7 SAC 118 \u00b7 FINAL/OT"
    ]
  },
  "companionActions": [
    {
      "id": "set_score_home",
      "label": "Set home score",
      "options": [
        {
          "id": "value",
          "label": "Score",
          "type": "number",
          "default": 0,
          "min": 0,
          "max": 999
        }
      ],
      "ops": [
        {
          "op": "set",
          "field": "scoreA",
          "value": {
            "option": "value"
          }
        }
      ]
    },
    {
      "id": "set_score_away",
      "label": "Set away score",
      "options": [
        {
          "id": "value",
          "label": "Score",
          "type": "number",
          "default": 0,
          "min": 0,
          "max": 999
        }
      ],
      "ops": [
        {
          "op": "set",
          "field": "scoreB",
          "value": {
            "option": "value"
          }
        }
      ]
    },
    {
      "id": "bump_score_home",
      "label": "Bump home score",
      "options": [
        {
          "id": "delta",
          "label": "Delta",
          "type": "number",
          "default": 1,
          "min": -3,
          "max": 3
        }
      ],
      "ops": [
        {
          "op": "add",
          "field": "scoreA",
          "value": {
            "option": "delta"
          },
          "min": 0
        }
      ]
    },
    {
      "id": "bump_score_away",
      "label": "Bump away score",
      "options": [
        {
          "id": "delta",
          "label": "Delta",
          "type": "number",
          "default": 1,
          "min": -3,
          "max": 3
        }
      ],
      "ops": [
        {
          "op": "add",
          "field": "scoreB",
          "value": {
            "option": "delta"
          },
          "min": 0
        }
      ]
    },
    {
      "id": "set_clock",
      "label": "Set game clock",
      "options": [
        {
          "id": "clock",
          "label": "Clock (MM:SS)",
          "type": "textinput",
          "default": "12:00"
        }
      ],
      "ops": [
        {
          "op": "set",
          "field": "clock",
          "value": {
            "option": "clock"
          }
        },
        {
          "op": "set",
          "field": "clockEndsAt",
          "value": 0
        }
      ]
    },
    {
      "id": "start_clock",
      "label": "Start game clock",
      "ops": [
        {
          "op": "countdown_start",
          "deadlineField": "clockEndsAt",
          "valueField": "clock",
          "format": "mm:ss"
        }
      ]
    },
    {
      "id": "stop_clock",
      "label": "Stop game clock",
      "ops": [
        {
          "op": "countdown_stop",
          "deadlineField": "clockEndsAt",
          "valueField": "clock",
          "format": "mm:ss"
        }
      ]
    },
    {
      "id": "reset_shot_clock",
      "label": "Reset shot clock",
      "options": [
        {
          "id": "seconds",
          "label": "Seconds",
          "type": "number",
          "default": 24,
          "min": 1,
          "max": 60
        }
      ],
      "ops": [
        {
          "op": "countdown_reset",
          "deadlineField": "shotEndsAt",
          "valueField": "shotClock",
          "format": "seconds",
          "value": {
            "option": "seconds"
          }
        }
      ]
    },
    {
      "id": "start_shot_clock",
      "label": "Start shot clock",
      "ops": [
        {
          "op": "countdown_start",
          "deadlineField": "shotEndsAt",
          "valueField": "shotClock",
          "format": "seconds"
        }
      ]
    },
    {
      "id": "stop_shot_clock",
      "label": "Stop shot clock",
      "ops": [
        {
          "op": "countdown_stop",
          "deadlineField": "shotEndsAt",
          "valueField": "shotClock",
          "format": "seconds"
        }
      ]
    },
    {
      "id": "set_quarter",
      "label": "Set quarter",
      "options": [
        {
          "id": "quarter",
          "label": "Quarter",
          "type": "number",
          "default": 1,
          "min": 1,
          "max": 4
        }
      ],
      "ops": [
        {
          "op": "set",
          "field": "quarter",
          "value": {
            "option": "quarter"
          }
        }
      ]
    },
    {
      "id": "set_possession",
      "label": "Set possession",
      "options": [
        {
          "id": "side",
          "label": "Possession",
          "type": "dropdown",
          "default": "a",
          "choices": [
            {
              "id": "a",
              "label": "Home"
            },
            {
              "id": "b",
              "label": "Away"
            },
            {
              "id": "",
              "label": "None"
            }
          ]
        }
      ],
      "ops": [
        {
          "op": "set",
          "field": "possession",
          "value": {
            "option": "side"
          }
        }
      ]
    },
    {
      "id": "toggle_bonus_home",
      "label": "Toggle home bonus",
      "ops": [
        {
          "op": "toggle",
          "field": "bonusA"
        }
      ]
    },
    {
      "id": "toggle_bonus_away",
      "label": "Toggle away bonus",
      "ops": [
        {
          "op": "toggle",
          "field": "bonusB"
        }
      ]
    },
    {
      "id": "set_timeout_home",
      "label": "Set home timeouts",
      "options": [
        {
          "id": "count",
          "label": "Timeouts",
          "type": "number",
          "default": 5,
          "min": 0,
          "max": 7
        }
      ],
      "ops": [
        {
          "op": "set",
          "field": "timeoutsA",
          "value": {
            "option": "count"
          }
        }
      ]
    },
    {
      "id": "set_timeout_away",
      "label": "Set away timeouts",
      "options": [
        {
          "id": "count",
          "label": "Timeouts",
          "type": "number",
          "default": 4,
          "min": 0,
          "max": 7
        }
      ],
      "ops": [
        {
          "op": "set",
          "field": "timeoutsB",
          "value": {
            "option": "count"
          }
        }
      ]
    },
    {
      "id": "show_player_card",
      "label": "Show player card",
      "ops": [
        {
          "op": "set",
          "field": "playerCard.visible",
          "value": true
        }
